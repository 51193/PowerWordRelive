<Project>
    <PropertyGroup>
        <RepoRoot>$(MSBuildThisFileDirectory)</RepoRoot>
        <OutputPath>$(RepoRoot)out/$(MSBuildProjectName)/</OutputPath>
        <CommonOutputDir>$(RepoRoot)out/</CommonOutputDir>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
    </PropertyGroup>

    <Target Name="CopyConfig" AfterTargets="Build">
        <Copy SourceFiles="$(RepoRoot)config" DestinationFolder="$(CommonOutputDir)"/>
    </Target>
</Project>
