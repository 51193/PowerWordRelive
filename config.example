# PowerWordRelive 配置文件
# 格式：domain.配置键: 值

# 进程定义（进程键 -> 项目名称）
processes.audio_capture: PowerWordRelive.AudioCapture
processes.speaker_split: PowerWordRelive.SpeakerSplit
processes.transcribe: PowerWordRelive.Transcribe
processes.transcription_store: PowerWordRelive.TranscriptionStore
processes.llm_requester: PowerWordRelive.LLMRequester
processes.local_backend: PowerWordRelive.LocalBackend
processes.remote_backend: PowerWordRelive.RemoteBackend

# 传递给各进程的配置域
process_config.audio_capture.domains: audio_capture,general
process_config.speaker_split.domains: speaker_split,general,huggingface
process_config.transcribe.domains: transcribe,general,modelscope
process_config.transcription_store.domains: transcription_store,storage,general
process_config.llm_requester.domains: llm_request,llm,general,storage,text_data
process_config.local_backend.domains: local_mode,remote_mode,local_backend,storage,general
process_config.remote_backend.domains: local_mode,remote_mode,general

# 通用配置 — work_root 必须是绝对路径
general.work_root: /absolute/path/to/work/root

# === 本地 Web 面板模式 ===
# Host 读取此配置决定是否启动本地 Web 面板
local_mode.enabled: true
local_mode.port: 9501

# === 本地后端轮询配置 ===
local_backend.poll_interval_sec: 3
local_backend.max_reconnect_attempts: 5
local_backend.initial_reconnect_delay_sec: 2

# === 远程模式配置 ===
# remote_mode.local.* — LocalBackend 连接本机 RemoteBackend 的配置
#   Host 在本地模式下注入 local.enabled、local.port、local.key
# remote_mode.remote.* — LocalBackend 连接远端服务器的配置
remote_mode.remote.enabled: false
remote_mode.remote.host: your.remote.server.com
remote_mode.remote.port: 9501
remote_mode.remote.key_path: ./keys/remote_key.bin

# remote_mode.server.* — 服务器端独立部署 RemoteBackend 时使用的配置
# 注意：以下配置仅在服务器上单独部署 RemoteBackend 时使用，本机部署时无效
remote_mode.server.port: 9501
remote_mode.server.key_path: /etc/pwr/remote_key.bin

# 音频捕获
audio_capture.output_dir: ./segments
audio_capture.sample_rate: 16000
audio_capture.silence_timeout_ms: 800
audio_capture.max_segment_sec: 120
audio_capture.no_speech_timeout_sec: 30
audio_capture.min_speech_ms: 500
audio_capture.windows_audio_device: VB-Audio Virtual Cable

# 说话人分离
speaker_split.input_dir: ./segments
speaker_split.output_dir: ./speaker_segments
speaker_split.embeddings_dir: ./speaker_embeddings
speaker_split.device: cpu
speaker_split.poll_interval_sec: 1
speaker_split.match_threshold: 0.55
speaker_split.omp_num_threads: 8
speaker_split.segmentation_batch_size: 64
speaker_split.embedding_batch_size: 64

# 语音转录
transcribe.input_dir: ./speaker_segments
transcribe.output_dir: ./transcriptions
transcribe.model: paraformer-zh
transcribe.device: cuda
transcribe.poll_interval_sec: 1

# 转录入库
transcription_store.input_dir: ./transcriptions
transcription_store.poll_interval_sec: 1

# LLM API
llm.token: 在此填入你的LLM API Token
llm.api_url: https://api.deepseek.com/v1/chat/completions

# 定时器
llm_request.timer.45: speaker_identification, refinement
llm_request.timer.90: story_progress, task, consistency

# 窗口限制
llm_request.window_limits.active_task: 30
llm_request.window_limits.consistency: 50

# Speaker ID 推断请求参数
llm_request.speaker_identification.model: deepseek-v4-pro
llm_request.speaker_identification.thinking_enabled: true
llm_request.speaker_identification.reasoning_effort: high
llm_request.speaker_identification.context_window: 2

# 精炼请求参数
llm_request.refinement.model: deepseek-v4-flash
llm_request.refinement.thinking_enabled: true
llm_request.refinement.reasoning_effort: high
llm_request.refinement.dialogue_window: 30
llm_request.refinement.refinement_window: 20

# 故事进展请求参数
llm_request.story_progress.model: deepseek-v4-flash
llm_request.story_progress.thinking_enabled: true
llm_request.story_progress.reasoning_effort: high
llm_request.story_progress.refinement_window: 20
llm_request.story_progress.story_progress_window: 15

# 任务系统请求参数
llm_request.task.model: deepseek-v4-flash
llm_request.task.thinking_enabled: true
llm_request.task.reasoning_effort: high
llm_request.task.refinement_window: 15
llm_request.task.story_progress_window: 10
llm_request.task.finished_task_window: 8

# 一致性表格请求参数
llm_request.consistency.model: deepseek-v4-flash
llm_request.consistency.thinking_enabled: true
llm_request.consistency.reasoning_effort: high
llm_request.consistency.refinement_window: 15
llm_request.consistency.story_progress_window: 10

# 持久化存储（SQLite）
storage.sqlite_path: ./data/pwr.db

# 文本资料
text_data.base_dir: text_data/

# HuggingFace 令牌
huggingface.token: 在此填入你的HuggingFace Token

# ModelScope 令牌
modelscope.token: （可选）在此填入你的ModelScope访问令牌
