<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\PowerWordRelive.Infrastructure\PowerWordRelive.Infrastructure.csproj"/>
    </ItemGroup>

    <Target Name="CopyPythonScript" AfterTargets="Build">
        <Copy SourceFiles="$(RepoRoot)scripts/vad_segmenter.py" DestinationFolder="$(OutputPath)"/>
    </Target>

    <Target Name="CopyRequirements" AfterTargets="Build">
        <Copy SourceFiles="$(RepoRoot)scripts/vad_venv.requirements.txt" DestinationFolder="$(OutputPath)"/>
    </Target>

    <Target Name="CopyDownloadScript" AfterTargets="Build">
        <Copy SourceFiles="$(RepoRoot)scripts/download_vad_model.py" DestinationFolder="$(OutputPath)"/>
    </Target>

</Project>
